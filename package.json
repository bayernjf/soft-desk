{
  "name": "soft-desk",
  "private": true,
  "version": "0.0.1",
  "description": "SoftDesk - 本地软件管理与智能启动工具",
  "author": "SoftDesk",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "restart": "pkill -f 'soft-desk.*Electron' 2>/dev/null || true; sleep 1; npm run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3,uiohook-napi",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && cross-env ELECTRON_BUILDER_CACHE=./.cache/electron-builder ELECTRON_CACHE=./.cache/electron ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --mac --publish never",
    "dist:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_BUILDER_CACHE=./.cache/electron-builder ELECTRON_CACHE=./.cache/electron ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win --publish never"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.511.0",
    "pinyin-pro": "^3.28.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.0.2",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.21.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.25.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.softdesk.app",
    "productName": "SoftDesk",
    "copyright": "Copyright © 2026 SoftDesk",
    "directories": {
      "output": "release"
    },
    "afterPack": "./scripts/after-pack.mjs",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.*",
      "build/trayTemplate*.png"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/uiohook-napi/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bayernjf",
        "repo": "soft-desk"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "build/icon.png",
      "executableName": "SoftDesk",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "SoftDesk"
    }
  }
}
